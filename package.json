{
  "name": "nest",
  "version": "0.7.1",
  "description": "Nest by RAVEN — Multi-AI Terminal Multiplexer",
  "author": "RAVEN",
  "repository": "https://github.com/GeronimoDiClemente/raven-nest",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "release:win": "electron-vite build && electron-builder --win --config.npmRebuild=false --publish always",
    "release:mac": "electron-vite build && electron-builder --mac --publish always",
    "package:win": "electron-vite build && electron-builder --win --config.npmRebuild=false --publish never",
    "package:mac": "electron-vite build && electron-builder --mac --publish never",
    "package:linux": "electron-vite build && electron-builder --linux --publish never",
    "release:linux": "electron-vite build && electron-builder --linux --publish always",
    "postinstall": "electron-rebuild -f -w node-pty"
  },
  "build": {
    "appId": "com.somosraven.nest",
    "productName": "Nest",
    "copyright": "© 2026 RAVEN",
    "publish": {
      "provider": "github",
      "owner": "GeronimoDiClemente",
      "repo": "raven-nest"
    },
    "extraResources": [
      {
        "from": "resources/icons",
        "to": "icons"
      }
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "resources/icons/icon.png",
      "category": "public.app-category.developer-tools"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "resources/icons/icon.ico",
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "icon": "resources/icons/icon.png",
      "category": "Development",
      "maintainer": "RAVEN <gerodc06@gmail.com>",
      "synopsis": "Multi-AI Terminal Multiplexer",
      "description": "Nest by RAVEN — Multi-AI Terminal Multiplexer"
    },
    "deb": {
      "depends": ["libgtk-3-0", "libnotify4", "libnss3", "libxss1", "libxtst6", "xdg-utils", "libatspi2.0-0", "libdrm2", "libgbm1", "libxcb-dri3-0"]
    },
    "protocols": [
      {
        "name": "Nest Deep Link",
        "schemes": ["nest"]
      }
    ],
    "files": [
      "dist/**",
      "dist-electron/**"
    ]
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@paddle/paddle-js": "^1.6.2",
    "@supabase/supabase-js": "^2.101.1",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/xterm": "^5.5.0",
    "electron-updater": "^6.8.3",
    "node-pty": "^1.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-resizable-panels": "^2.1.7"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.1",
    "@resvg/resvg-js": "^2.6.2",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^3.0.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.5"
  }
}
