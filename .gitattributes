# Normalize line endings on text files so Windows / macOS / Linux contributors
# don't generate spurious LF↔CRLF diffs.
* text=auto eol=lf

# Common binaries — never normalize.
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.icns  binary
*.dmg   binary
*.zip   binary
*.exe   binary
*.AppImage binary
*.deb   binary
